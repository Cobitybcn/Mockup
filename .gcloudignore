# .gcloudignore
# This file specifies files and directories that should be uploaded to GCP Cloud Build.

.git
.gitignore

jobs
results
uploads
logs
logs/
logs/*
logs/**
backups
scratch
analysis
dump_output.txt
mockup-prompts/*
!mockup-prompts/.htaccess
assets/showcase/*
!assets/showcase/latest_mockup_1.jpg
!assets/showcase/latest_mockup_2.jpg
!assets/showcase/latest_mockup_3.jpg
!assets/showcase/34-right-view-attic-studio-3-4-right-view-medium-test-piece-mockup-02.jpg
!assets/showcase/floor-leaning.jpg
!assets/showcase/nadir.jpg
/vendor
*.log
__pycache__/
*.pyc
.env
.agents/
.claude/
.codex/
.idea/
.vscode/

# Ignore all contents in storage/ by default
storage/*

# Re-include the world_mothers folder structure and the index.json metadata
!storage/world_mothers/
storage/world_mothers/*
!storage/world_mothers/index.json
