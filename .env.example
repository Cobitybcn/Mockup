# Configuración de Entorno - ARTMOCK

# Modo de ejecución de la aplicación: 'mock' (simulado local) o 'openai' (real con APIs de OpenAI o Gemini)
APP_MODE=mock

# Permitir consumo real de APIs (debe ser true si APP_MODE=openai)
ALLOW_REAL_API=false

# Proveedor de generación de imágenes: 'openai' o 'gemini'
IMAGE_PROVIDER=openai

# API Key y configuraciones de OpenAI
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_IMAGE_QUALITY=standard
OPENAI_IMAGE_SIZE=1024x1024

# API Key y configuraciones de Gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Emails de administradores separados por comas
ADMIN_EMAILS=
