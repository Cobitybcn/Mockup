# Dockerfile.web
FROM php:8.2.32-apache-bookworm

# Install system dependencies and PHP mysql extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    libzip-dev \
    libcurl4-openssl-dev \
    zip \
    unzip \
    python3 \
    python3-pip \
    libpng-dev \
    libjpeg-dev \
    libwebp-dev \
    libfreetype6-dev \
    && docker-php-ext-configure gd --with-freetype --with-jpeg --with-webp \
    && docker-php-ext-install curl zip pdo_mysql bcmath gd \
    && rm -rf /var/lib/apt/lists/*

# Install python dependencies for Vertex AI bridge
RUN pip3 install --no-cache-dir --break-system-packages google-genai==2.12.1 Pillow==12.3.0

# Enable the Apache modules used by routing and the production security policy.
RUN a2enmod rewrite headers

# Configure PHP settings
RUN echo "upload_max_filesize = 200M" > /usr/local/etc/php/conf.d/uploads.ini \
    && echo "post_max_size = 512M" >> /usr/local/etc/php/conf.d/uploads.ini \
    && echo "memory_limit = 768M" >> /usr/local/etc/php/conf.d/uploads.ini

# Copy composer
COPY --from=composer:2.10.2 /usr/bin/composer /usr/bin/composer

# Set working directory
WORKDIR /var/www/html

# Install PHP dependencies before copying the app so Docker can cache Composer
# when only PHP/source files change.
COPY platform/composer.json platform/composer.lock /var/www/html/
RUN composer install --no-dev --no-interaction --prefer-dist --no-progress --classmap-authoritative

# Copy codebase
COPY platform/ /var/www/html/
COPY site-admin/ /var/www/html/site-admin/

# Install a deny-by-default policy for internal code, runtime data, diagnostics,
# and worker entry points. These files must never be reachable from the public
# web service even if a future build accidentally copies them again.
COPY platform/apache-security.conf /etc/apache2/conf-available/artworkmockups-security.conf
RUN a2enconf artworkmockups-security

# Keep the small public-site contract fixture beside the platform image so the
# production regression suite validates both deployable surfaces before release.
COPY artist-site/index.php /var/www/artist-site/index.php
COPY artist-site/inc/header.php /var/www/artist-site/inc/header.php
COPY artist-site/inc/functions.php /var/www/artist-site/inc/functions.php
COPY artist-site/inc/TenantResolver.php /var/www/artist-site/inc/TenantResolver.php
COPY artist-site/inc/AppStore.php /var/www/artist-site/inc/AppStore.php
COPY artist-site/inc/StripeCheckout.php /var/www/artist-site/inc/StripeCheckout.php
COPY artist-site/inc/AppPublishedSeriesCatalog.php /var/www/artist-site/inc/AppPublishedSeriesCatalog.php
COPY artist-site/assets/css/styles.css /var/www/artist-site/assets/css/styles.css

# Configure Apache port to 8080 (Cloud Run standard)
RUN sed -i 's/Listen 80/Listen 8080/g' /etc/apache2/ports.conf
RUN sed -i 's/<VirtualHost \*:80>/<VirtualHost \*:8080>/g' /etc/apache2/sites-available/000-default.conf
RUN sed -i '/<VirtualHost \*:8080>/a\    RewriteEngine On\n    RewriteRule ^/?integrations/pinterest/callback$ /integrations/pinterest/callback/index.php [END]\n    RewriteRule ^/?integrations/meta/callback$ /integrations/meta/callback/index.php [END]\n    RewriteRule ^/?integrations/instagram/callback$ /integrations/instagram/callback/index.php [END]' /etc/apache2/sites-available/000-default.conf

# Set permissions
RUN chown -R www-data:www-data /var/www/html

EXPOSE 8080
