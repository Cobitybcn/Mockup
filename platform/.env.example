# Configuración de Entorno - ARTMOCK

# El entorno local solo puede conectarse a una base cuyo nombre contenga "local".
# Cloud Run inyecta su propia configuracion y debe usar APP_ENV=production.
APP_ENV=local
# Vista previa reversible: requiere ADMIN o un revisor local explícito.
UI_VISUAL_CONSISTENCY_PREVIEW=false
UI_VISUAL_CONSISTENCY_PREVIEW_REVIEWERS=
# These flags are explicit in production CI as well; do not rely on defaults.
FEATURE_WEBSITE_ENABLED=true
FEATURE_SOCIAL_ENABLED=true
FEATURE_VIDEO_ENABLED=true

# Modo de ejecución de la aplicación:
#   'mock'   → simulado local, sin consumir APIs (desarrollo)
#   'gemini' → modo real con Gemini/Vertex AI (punto #1: nuevo modo explícito)
#   'openai' → modo real con OpenAI (alias retrocompatible, también acepta Gemini si IMAGE_PROVIDER=gemini)
APP_MODE=mock

# Permitir consumo real de APIs (debe ser true si APP_MODE es gemini u openai)
ALLOW_REAL_API=false

# Artist plan rollout switches. Admin users always retain access for testing.
# A per-user allow/deny override from Users & Credits takes precedence.
FEATURE_WEBSITE_ENABLED=true
FEATURE_SOCIAL_ENABLED=true
FEATURE_VIDEO_ENABLED=true

# Proveedor de generación de imágenes: 'openai' o 'gemini'
IMAGE_PROVIDER=gemini
MOCKUP_FIDELITY_GATE_ENABLED=true
MOCKUP_FIDELITY_FAIL_OPEN=false
MOCKUP_FIDELITY_MAX_REGENERATIONS=2
MOCKUP_FIDELITY_MIN_SCORE=72
MOCKUP_FIDELITY_REVIEW_MODEL=gemini-2.5-flash

# API Key y configuraciones de OpenAI
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_IMAGE_QUALITY=standard
OPENAI_IMAGE_SIZE=1024x1024

# Asistente contextual privado. En producción, OPENAI_API_KEY debe inyectarse desde Secret Manager.
OPENAI_ASSISTANT_MODEL=gpt-5.6-terra
OPENAI_API_BASE=https://api.openai.com/v1
ASSISTANT_ENABLED=false
ASSISTANT_ADMIN_ENABLED=true
ASSISTANT_APP_ENABLED=true
ASSISTANT_ALLOWED_EMAILS=
ASSISTANT_PROVIDER=openai
# Optional Gemini override. Leave blank to reuse VERTEX_PROJECT_ID / VERTEX_LOCATION.
ASSISTANT_VERTEX_PROJECT_ID=
ASSISTANT_VERTEX_LOCATION=
ASSISTANT_GOOGLE_APPLICATION_CREDENTIALS=
ASSISTANT_MAX_OUTPUT_TOKENS=1200
ASSISTANT_HISTORY_MESSAGES=12
ASSISTANT_RATE_LIMIT_PER_MINUTE=12
ASSISTANT_DAILY_MESSAGE_LIMIT=250

# API Key y configuraciones de Gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# ID del proyecto en Google Cloud / Vertex AI (punto #4)
# Si se deja vacío se usa el valor por defecto configurado en config.php
VERTEX_PROJECT_ID=

# Emails de administradores separados por comas
ADMIN_EMAILS=

# Base de datos: sqlite o mysql.
# Para migrar de forma segura: primero ejecutar scripts/migrate_sqlite_to_mysql.php,
# verificar conteos, y recien despues cambiar DB_CONNECTION=mysql en .env.
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=artwork_mockups_local_v2
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Cantidad de mockups automaticos que se generan en paralelo.
# Admin puede cambiarlo desde API Settings. Rango seguro: 1 a 8.
MOCKUP_WORKER_COUNT=4

# Ruta absoluta al ejecutable PHP (solo necesario en Windows/Laragon) (punto #2)
# Si se deja vacío, el sistema detecta automáticamente la versión más reciente en C:\laragon\bin\php\
# Ejemplo: PHP_BINARY_PATH=C:\laragon\bin\php\php-8.3.30-Win32-vs16-x64\php.exe
PHP_BINARY_PATH=

# Ruta absoluta al ejecutable Python con google.genai instalado (punto #3)
# Si se deja vacío, el sistema busca automáticamente en candidatos conocidos
# Ejemplo: PYTHON_BINARY_PATH=C:\laragon\bin\python\python-3.13\python.exe
PYTHON_BINARY_PATH=

# Configuración del entorno GCP & Serverless (Fase 1 PoC y producción)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_QUEUE_NAME=mockups-generation-queue
GCP_SOCIAL_QUEUE_NAME=social-publication-queue
# Optional. Leave empty to reuse GCP_QUEUE_NAME without creating infrastructure.
GCP_VIDEO_QUEUE_NAME=
GCP_WORKER_URL=
GCP_TASKS_INVOKER_SA=
GCS_BUCKET_NAME=
# Video Studio: keep the worker token in Secret Manager in production.
VIDEO_WORKER_TOKEN=
VIDEO_VERTEX_PROJECT_ID=
VIDEO_VERTEX_LOCATION=us-central1
VIDEO_GENERATION_PROVIDER=vertex_gemini_omni
VIDEO_OMNI_MODEL=gemini-omni-flash-preview
VIDEO_VEO_MODEL=veo-3.1-fast-generate-001
VIDEO_VEO_RESOLUTION=720p
# Test/maintenance switch. When true, jobs remain queued for manual workers.
VIDEO_DISABLE_BACKGROUND_JOBS=false
# Public canonical base used by landings and social publishing (no trailing slash).
APP_PUBLIC_URL=https://artworkmockups.com
ARTIST_WEBSITE_CATALOG_URL=https://mauriziovalch.com/artworks
SAATCHI_ARTIST_URL=https://www.saatchiart.com/mauriziovalch

# Official Artwork Mockups Pinterest OAuth app. Every artist authorizes their
# own Pinterest account; tokens remain separated by user and purpose.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=https://artworkmockups.com/integrations/pinterest/callback
# 32 random bytes encoded as Base64; store as a managed secret in production.
PINTEREST_TOKEN_KEY=
PINTEREST_LIVE_PUBLISH_ENABLED=false
PINTEREST_DRAFT_PUBLIC_MEDIA_ENABLED=false
# Use sandbox while the Pinterest app has Trial access. Sandbox requires its own token/OAuth connection.
PINTEREST_API_ENVIRONMENT=production
# Separate token generated in Pinterest's API Sandbox. Never reuse the production OAuth token.
PINTEREST_SANDBOX_TOKEN=
# Temporary read-only bridge while Trial access is pending. Use only a
# Pinterest "Production Limited" token and scope it to its local admin owner.
PINTEREST_PRODUCTION_READ_TOKEN=
PINTEREST_PRODUCTION_READ_USER_ID=0

# Private editorial synchronization with an artist website.
ARTWORK_WEBSITE_V2_ENDPOINT=
ARTWORK_SYNC_SHARED_SECRET=

# Meta OAuth. Artist and platform are intentionally separate applications/credentials.
META_GRAPH_VERSION=v25.0
META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts
META_APP_ID_ARTIST=
META_APP_SECRET_ARTIST=
META_REDIRECT_URI_ARTIST=https://artworkmockups.com/integrations/meta/callback?purpose=artist
META_APP_ID_PLATFORM=
META_APP_SECRET_PLATFORM=
META_REDIRECT_URI_PLATFORM=https://artworkmockups.com/integrations/meta/callback?purpose=platform
# One shared 32-byte Base64 key is sufficient; tokens remain separated by purpose.
META_TOKEN_KEY=
# Both controls must be true before the review screen can create real posts.
META_OAUTH_ENABLED=false
META_LIVE_PUBLISH_ENABLED=false
META_DRAFT_PUBLIC_MEDIA_ENABLED=false

# Direct Instagram Login for professional Creator/Business accounts.
# These credentials are supplied by the Instagram API setup in the Meta app.
INSTAGRAM_GRAPH_VERSION=v25.0
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_APP_ID_ARTIST=
INSTAGRAM_APP_SECRET_ARTIST=
INSTAGRAM_REDIRECT_URI_ARTIST=https://artworkmockups.com/integrations/instagram/callback
# 32 random bytes encoded as Base64; keep it in Secret Manager in production.
INSTAGRAM_TOKEN_KEY=
INSTAGRAM_OAUTH_ENABLED=false
INSTAGRAM_LIVE_PUBLISH_ENABLED=false
INSTAGRAM_DRAFT_PUBLIC_MEDIA_ENABLED=false

# Contact form SMTP. Store SMTP_PASSWORD in Secret Manager in production.
CONTACT_RECIPIENT_EMAIL=mauriziovalch@gmail.com
CONTACT_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=
SMTP_PASSWORD=
