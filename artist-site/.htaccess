RewriteEngine On
Options -Indexes

<FilesMatch "^(Dockerfile(?:\..*)?|\.dockerignore|\.gcloudignore(?:\..*)?|cloudbuild(?:\..*)?\.ya?ml)$">
    Require all denied
</FilesMatch>

RewriteRule ^artworks(?:/.*)?$ index.php [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
