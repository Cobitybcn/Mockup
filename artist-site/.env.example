# Local deployment credentials. Copy to .env and complete locally.
ARTIST_SITE_SFTP_HOST=
ARTIST_SITE_SFTP_PORT=22
ARTIST_SITE_SFTP_USER=
ARTIST_SITE_SFTP_PASSWORD=
ARTIST_SITE_SFTP_ROOT=

# Shared with Artwork Mockups. Use at least 32 random characters.
ARTWORK_SYNC_SHARED_SECRET=

# Stripe credentials are entered per artist in Store Admin and stored encrypted.
# This key normally comes from the shared platform environment.
STRIPE_CREDENTIALS_KEY=
ARTIST_SITE_PUBLIC_URL=

# Contact form. Keep SMTP_PASSWORD in Secret Manager in production.
CONTACT_RECIPIENT_EMAIL=studio@mauriziovalch.com
CONTACT_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=
SMTP_PASSWORD=
