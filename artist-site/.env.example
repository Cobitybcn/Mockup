# Local deployment credentials. Copy to .env and complete locally.
ARTIST_SITE_SFTP_HOST=
ARTIST_SITE_SFTP_PORT=22
ARTIST_SITE_SFTP_USER=
ARTIST_SITE_SFTP_PASSWORD=
ARTIST_SITE_SFTP_ROOT=

# Shared with Artwork Mockups. Use at least 32 random characters.
ARTWORK_SYNC_SHARED_SECRET=

# Optional local overrides. Production should inject platform Connect secrets.
STRIPE_CONNECT_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=
ARTIST_SITE_PUBLIC_URL=
